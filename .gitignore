# ============================================================
# Python cache files
# ============================================================
__pycache__/
*.py[cod]
*$py.class

# ============================================================
# Virtual environments
# ============================================================
.venv/
venv/
env/
ENV/

# ============================================================
# IDE config
# ============================================================
.idea/
.vscode/

# ============================================================
# Build / packaging files
# ============================================================
*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/

# ============================================================
# Local generated vector index and logs
# These files can be regenerated by:
# python -m dehaze_rag.build_index
# ============================================================
data/index/
data/logs/

# ============================================================
# PDF papers
# Do not upload papers to GitHub to avoid copyright issues.
# ============================================================
papers/*.pdf

# ============================================================
# Environment variables / API keys
# Never upload real API keys.
# ============================================================
.env
.env.*

# ============================================================
# Agent generated reports
# Local generated reports are ignored by default.
# If you want to upload examples, put selected files under docs/examples/.
# ============================================================
reports/

# ============================================================
# Evaluation outputs
# Evaluation scripts are uploaded, but generated CSV results are ignored.
# ============================================================
eval_results/

# ============================================================
# System files
# ============================================================
.DS_Store
Thumbs.db