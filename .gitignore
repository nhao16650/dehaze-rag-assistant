# ============================================================
# Python cache files
# Python 缓存文件，不上传
# ============================================================
__pycache__/
*.py[cod]
*$py.class


# ============================================================
# Virtual environments
# 虚拟环境，不上传
# ============================================================
.venv/
venv/
env/
ENV/


# ============================================================
# PyCharm / IDE config
# PyCharm 配置文件，不上传
# ============================================================
.idea/
.vscode/


# ============================================================
# Build / packaging files
# Python 打包、安装缓存文件，不上传
# ============================================================
*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/


# ============================================================
# Local generated data
# 本地生成的向量库、日志文件，不上传
# 这些文件可以通过 python -m dehaze_rag.build_index 重新生成
# ============================================================
data/index/
data/logs/


# ============================================================
# PDF papers
# 论文 PDF 不上传，避免版权问题
# ============================================================
papers/*.pdf


# ============================================================
# Environment variables / API keys
# 环境变量和 API Key 文件，不上传
# ============================================================
.env
.env.*


# ============================================================
# System files
# 系统文件，不上传
# ============================================================
.DS_Store
Thumbs.db